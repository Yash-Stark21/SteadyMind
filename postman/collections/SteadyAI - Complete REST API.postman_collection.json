    "_postman_id": "b2f46cb0-7895-49a6-b7b8-0f8c1b684b25",
    "name": "SteadyAI - Complete REST API",
    "description": "Detailed Postman collection for the SteadyAI `/api/**` REST surface. Collection-level auth uses JWT Bearer token from `{{accessToken}}`. Run an Auth > Login request first to populate the token.\n\n## Test Credentials\nThe database seeds these users automatically (all share the password `password123`):\n- `user@example.com` (ROLE_USER)\n- `admin@example.com` (ROLE_ADMIN)\n- `therapist@example.com` (ROLE_THERAPIST)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.test('No unexpected server error', function () {",
          "  pm.expect(pm.response.code).to.be.below(500);",
          "});"
        ]
      }
    }
  ],
