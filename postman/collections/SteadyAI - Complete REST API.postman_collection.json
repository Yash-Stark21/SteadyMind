  "item": [
    {
      "name": "Auth",
      "description": "Public registration/login plus authenticated current-user lookup. Login responses save `accessToken`, `currentUserId`, and role variables for later requests.",
      "item": [
        {
          "name": "Register User",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{registerName}}\",\n  \"email\": \"postman.user+{{$timestamp}}@example.com\",\n  \"password\": \"{{registerPassword}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/api/auth/register",
            "description": "Public endpoint. Creates a new `ROLE_USER` account. Validation: `name`, valid `email`, and `password` of at least 6 characters are required."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Register returns 200 OK', function () {",
                  "  pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Login - User Token",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{password}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/api/auth/login",
            "description": "Public endpoint. Authenticates a regular user and stores the JWT in `{{accessToken}}` for collection-level Bearer auth."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login returns a Bearer token', function () {",
                  "  pm.response.to.have.status(200);",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.accessToken).to.be.a('string').and.not.empty;",
                  "  pm.expect(json.tokenType).to.eql('Bearer');",
                  "});",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('accessToken', json.accessToken);",
                  "pm.collectionVariables.set('currentUserId', json.user.id);",
                  "pm.collectionVariables.set('currentUserRole', json.user.role);",
                  "pm.collectionVariables.set('userId', json.user.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Login - Admin Token",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{password}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/api/auth/login",
            "description": "Public endpoint. Authenticates the seeded admin account and stores an admin JWT for `/api/admin/**` routes."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Admin login returns ROLE_ADMIN', function () {",
                  "  pm.response.to.have.status(200);",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.user.role).to.eql('ROLE_ADMIN');",
                  "});",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('accessToken', json.accessToken);",
                  "pm.collectionVariables.set('currentUserId', json.user.id);",
                  "pm.collectionVariables.set('currentUserRole', json.user.role);"
                ]
              }
            }
          ]
        },
        {
          "name": "Login - Therapist Token",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{therapistEmail}}\",\n  \"password\": \"{{password}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/api/auth/login",
            "description": "Public endpoint. Authenticates the seeded therapist account and stores a therapist JWT for `/api/therapist/**` routes."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Therapist login returns ROLE_THERAPIST', function () {",
                  "  pm.response.to.have.status(200);",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.user.role).to.eql('ROLE_THERAPIST');",
                  "});",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('accessToken', json.accessToken);",
                  "pm.collectionVariables.set('currentUserId', json.user.id);",
                  "pm.collectionVariables.set('currentUserRole', json.user.role);",
                  "pm.collectionVariables.set('therapistId', json.user.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/auth/me",
            "description": "Requires Bearer token. Returns the authenticated user's `id`, `name`, `email`, and `role`."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Current user is returned', function () {",
                  "  pm.response.to.have.status(200);",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.include.keys('id', 'name', 'email', 'role');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Logout - Current Token",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/api/auth/logout",
            "description": "Requires Bearer token. Stateless JWT logout endpoint; the server returns success and the client should discard the current token. The test script does not clear `{{accessToken}}` automatically so full collection runs can continue."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Logout accepted for current token', function () {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(pm.response.json().message).to.eql('Logged out successfully. Discard the bearer token on the client.');",
                  "});",
                  "// To make this request discard the Postman token variable, uncomment the next line.",
                  "// pm.collectionVariables.unset('accessToken');"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Urge Logs",
      "description": "User-scoped CRUD for moment logs. Requires a `ROLE_USER` token.",
      "item": [
        {
          "name": "Create Urge Log",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"triggerText\": \"Saw a news article about contamination\",\n  \"obsessionText\": \"What if I got contaminated?\",\n  \"compulsionUrge\": \"Wash hands repeatedly\",\n  \"intensityBefore\": 8,\n  \"delayMinutes\": 5,\n  \"intensityAfter\": 4,\n  \"compulsionPerformed\": false\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/api/urge-logs",
            "description": "Creates an urge log. Validation: `triggerText`, `compulsionUrge`, `intensityBefore`, `delayMinutes`, and `compulsionPerformed` are required. `delayMinutes` must be one of `0`, `2`, `5`, `10`, `15`; intensity values are `1` to `10`."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Urge log created', function () {",
                  "  pm.response.to.have.status(201);",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.id).to.be.a('number');",
                  "});",
                  "pm.collectionVariables.set('urgeLogId', pm.response.json().id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Get All Urge Logs",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/urge-logs",
            "description": "Lists the authenticated user's urge logs ordered by newest first."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Urge log list returned', function () {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(pm.response.json()).to.be.an('array');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Urge Log By ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/urge-logs/{{urgeLogId}}",
            "description": "Fetches one urge log owned by the authenticated user. Returns 404 if the ID is missing or belongs to another user."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Urge log returned', function () {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(pm.response.json().id).to.eql(Number(pm.collectionVariables.get('urgeLogId')));",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Update Urge Log",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"triggerText\": \"Touched a public door handle\",\n  \"obsessionText\": \"What if I spread germs?\",\n  \"compulsionUrge\": \"Wash hands for a long time\",\n  \"intensityBefore\": 7,\n  \"delayMinutes\": 10,\n  \"intensityAfter\": 3,\n  \"compulsionPerformed\": false\n}",
              "options": {
