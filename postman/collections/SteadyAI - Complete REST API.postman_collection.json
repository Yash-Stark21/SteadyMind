            "description": "Requires `ROLE_ADMIN`. Assigns a therapist to a user using query parameters `therapistId` and `userId`. Re-running for the same pair returns 400 because duplicate assignments are rejected."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
