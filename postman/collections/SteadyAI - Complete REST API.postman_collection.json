      "name": "Admin",
      "description": "Admin-only user and therapist assignment routes. Run Auth > Login - Admin Token before these requests.",
      "item": [
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/admin/users",
            "description": "Requires `ROLE_ADMIN`. Lists users with `id`, `name`, `email`, and `role`. The test script stores the first `ROLE_USER` as `{{userId}}` and first `ROLE_THERAPIST` as `{{therapistId}}`."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Admin user list returned', function () {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(pm.response.json()).to.be.an('array');",
                  "});",
                  "const users = pm.response.json();",
                  "const user = users.find(item => item.role === 'ROLE_USER');",
                  "const therapist = users.find(item => item.role === 'ROLE_THERAPIST');",
                  "if (user) pm.collectionVariables.set('userId', user.id);",
                  "if (therapist) pm.collectionVariables.set('therapistId', therapist.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Assign Therapist",
          "request": {
            "method": "POST",
