                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/api/urge-logs/{{urgeLogId}}",
            "description": "Replaces the editable fields for one owned urge log. Uses the same validation rules as create."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Urge log updated', function () {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(pm.response.json().triggerText).to.eql('Touched a public door handle');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Delete Urge Log",
          "request": {
            "method": "DELETE",
