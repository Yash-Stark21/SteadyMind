    {
      "name": "Compulsion Delay Attempts",
      "description": "User-scoped delay attempt lifecycle. Requires a `ROLE_USER` token. Completion and cancellation are mutually exclusive once an outcome is set.",
      "item": [
        {
          "name": "Create Delay Attempt",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"urgeLogId\": null,\n  \"exposureTaskId\": null,\n  \"triggerDescription\": \"Felt the urge to check the lock again\",\n  \"plannedDelayMinutes\": 5,\n  \"copingStrategyUsed\": \"BREATHING\",\n  \"notes\": \"Trying a short delay before deciding what to do.\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/api/compulsion-delay-attempts",
            "description": "Creates a delay attempt. Optional links: `urgeLogId` and `exposureTaskId` may be set to `{{urgeLogId}}` and `{{exposureTaskId}}` after creating those resources; linked IDs must belong to the current user. Allowed coping strategies: `BREATHING`, `WALKING`, `JOURNALING`, `COLD_WATER`, `CALL_SUPPORT`, `DISTRACTION`, `DELAY_TIMER`, `OTHER`."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Delay attempt created', function () {",
                  "  pm.response.to.have.status(201);",
                  "  pm.expect(pm.response.json().id).to.be.a('number');",
                  "});",
                  "pm.collectionVariables.set('delayAttemptId', pm.response.json().id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Get All Delay Attempts",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/compulsion-delay-attempts",
            "description": "Lists the authenticated user's delay attempts ordered by newest first."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Delay attempt list returned', function () {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(pm.response.json()).to.be.an('array');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Delay Attempt By ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/compulsion-delay-attempts/{{delayAttemptId}}",
            "description": "Fetches one delay attempt owned by the authenticated user."
