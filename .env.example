# Fast local demo: no MySQL and no OpenAI network call.
SPRING_PROFILES_ACTIVE=demo,mock-ai
STEADYAI_JWT_SECRET=replace-with-a-strong-32-byte-minimum-secret

# MySQL runtime profile values, only needed when not using the demo profile.
STEADYAI_DATASOURCE_URL=jdbc:mysql://localhost:3306/steadyai?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
STEADYAI_DATASOURCE_USERNAME=steadyai
STEADYAI_DATASOURCE_PASSWORD=replace-with-your-db-password
STEADYAI_JPA_DDL_AUTO=update
STEADYAI_JPA_SHOW_SQL=false

# OpenAI-backed AI profile, only needed when SPRING_PROFILES_ACTIVE includes openai.
OPENAI_API_KEY=replace-with-your-key
